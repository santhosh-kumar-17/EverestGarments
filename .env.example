# ============================================
# Everest Garments - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!

# ============================================
# DATABASE - MongoDB Atlas
# ============================================
# Get your connection string from:
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a cluster
# 3. Click "Connect" → "Drivers"
# 4. Copy the connection string
# 5. Replace <password> with your database user password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/everest?retryWrites=true&w=majority

# ============================================
# FILE STORAGE - Cloudinary
# ============================================
# Get these from https://cloudinary.com/console
# 1. Sign up for free account
# 2. Go to Dashboard
# 3. Copy Cloud Name, API Key, and API Secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your_super_secret_api_secret

# ============================================
# SECURITY - JWT Secret
# ============================================
# Generate a secure secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or run: npm run setup
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here_1234567890

# ============================================
# ADMIN CREDENTIALS
# ============================================
# Username for admin login (can be any string)
ADMIN_USERNAME=admin

# Password hash for admin (bcryptjs)
# Generate with: npm run setup
# Or: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('yourpassword', 10).then(h => console.log(h));"
ADMIN_PASSWORD_HASH=$2b$10$abcdefghijklmnopqrstuvwxyz123456789

